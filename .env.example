# Database — use Netlify DB or any Postgres (Neon, Supabase, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth (generate: openssl rand -hex 32)
AUTH_SECRET="change-me-long-random-string"
AUTH_URL="https://your-site.netlify.app"
NEXT_PUBLIC_SITE_URL="https://your-site.netlify.app"

# First author login (used when you run: npm run db:seed)
ADMIN_EMAIL="author@example.com"
ADMIN_PASSWORD="change-me-on-first-login"

# Optional: newsletter (Resend)
RESEND_API_KEY=""
