# Copy to `.env` for local development (never commit `.env`).

# Required: PostgreSQL (e.g. free tier from https://neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Required for sign-in (NextAuth). Use a long random string in production.
AUTH_SECRET="replace-with-a-long-random-secret"

# Public URL of the site (set automatically on some hosts; required locally)
# AUTH_URL="http://localhost:3000"
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Seed the first author user (see prisma/seed.ts)
ADMIN_EMAIL="author@example.com"
ADMIN_PASSWORD="change-me-on-first-login"

# Optional: run migrations + seed when the server process starts (Netlify sets NETLIFY=1;
# on other hosts set this to 1 if you do not use a release/migrate command)
# RUN_DB_SETUP_ON_BOOT=1

# Optional: transactional email (newsletter)
# RESEND_API_KEY=
