# Copy to `.env` for local dev, or paste into Vercel → Settings → Environment Variables.

# Required — free Postgres: https://neon.tech → New project → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

AUTH_SECRET="local-dev-secret-replace-in-production"

# Local only (Vercel sets these automatically):
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

ADMIN_EMAIL="author@example.com"
ADMIN_PASSWORD="change-me-on-first-login"

# Optional: newsletter
# RESEND_API_KEY=
